# CertiFlow Environment Variables
# Copy this file to .env and update values

# Core
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (SQLite for development - change for PostgreSQL in production)
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3

# PostgreSQL (uncomment and fill for production)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=certiflow_db
# DB_USER=certiflow_user
# DB_PASSWORD=your_db_password
# DB_HOST=localhost
# DB_PORT=5432

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=CertiFlow <noreply@certiflow.com>

# Media & Static
MEDIA_URL=/media/
STATIC_URL=/static/

# QR Code Settings
QR_REFRESH_INTERVAL=20

# Certificate Settings
CERT_SECRET_KEY=your-cert-signing-key-change-in-production

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Site URL (used for verification links)
SITE_URL=http://localhost:8000

# Security (set in production)
CSRF_TRUSTED_ORIGINS=http://localhost:8000
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
